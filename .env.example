# Database Configuration
# PostgreSQL (Local ou Remoto)
DATABASE_URL=postgresql://postgres:123456@localhost:5432/fiscal_db

# Ou para Azure PostgreSQL
# DATABASE_URL=postgresql://user@servername:password@servername.postgres.database.azure.com:5432/fiscal_db

# Ou para Railway
# DATABASE_URL=postgresql://user:password@railway.app:5432/fiscal_db

# Ou para Render
# DATABASE_URL=postgresql://user:password@dpg-xxxxx.xxx.railway.app:5432/fiscal_db
